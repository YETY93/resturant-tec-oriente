<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Productos - Restaurante</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="header">
    <div class="container">
      <h1 class="logo">🍽️ Restaurante Tec Oriente</h1>
      <nav class="nav">
        <% if (locals.user) { %>
          <a href="/tables" class="nav-link">Mesas</a>
          <a href="/products" class="nav-link active">Productos</a>
          <a href="/dashboard" class="nav-link">Pedidos</a>
          <a href="/orders" class="nav-link">Historial</a>
          <span class="nav-user">👤 <%= user.username %></span>
          <form action="/logout" method="POST" class="form-logout">
            <button type="submit" class="btn btn-logout">Salir</button>
          </form>
        <% } else { %>
          <a href="/login" class="nav-link">Ingresar</a>
          <a href="/register" class="nav-link">Registrarse</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="main">
    <div class="container">
      <div class="page-header">
        <h2>Catálogo de Productos</h2>
        <p class="page-subtitle">Gestiona el menú del restaurante</p>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>Agregar Nuevo Producto</h3>
        </div>
        <div class="card-body">
          <form action="/products" method="POST" class="form-inline" onsubmit="return validateProductLimit()">
            <div class="form-group">
              <label for="name">Nombre del Producto:</label>
              <input type="text" id="name" name="name" required class="form-control" placeholder="Ej: Pizza Margarita">
            </div>
            <div class="form-group">
              <label for="price">Precio:</label>
              <input type="number" id="price" name="price" min="0.01" step="0.01" required class="form-control" placeholder="Ej: 15.50">
            </div>
            <button type="submit" class="btn btn-primary">
              <span class="icon">+</span> Agregar
            </button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>Lista de Productos (<%= products.length %>)</h3>
        </div>
        <div class="card-body">
          <% if (products.length > 0) { %>
            <div class="table-responsive">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% products.forEach(function(product) { %>
                    <tr>
                      <td><strong>#<%= product.id %></strong></td>
                      <td><%= product.name %></td>
                      <td class="price-cell">$ <%= product.price.toFixed(2) %></td>
                      <td>
                        <form action="/products/<%= product.id %>/delete" method="POST" class="form-delete" onsubmit="return confirm('¿Eliminar <%= product.name %>?)">
                          <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                        </form>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="empty-state">
              <p>No hay productos registrados. Agrega el primer producto arriba.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <!-- Modal de Upgrade -->
  <div id="upgradeModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <span class="modal-icon">🚀</span>
        <h3>¿Necesitas más productos?</h3>
      </div>
      <div class="modal-body">
        <p class="modal-message">
          Has alcanzado el límite de productos gratuitos (10 productos).
        </p>
        <p class="modal-description">
          Si deseas agregar más productos y acceder a características avanzadas como:
        </p>
        <ul class="modal-features">
          <li>✓ Catálogo de productos ilimitado</li>
          <li>✓ Categorías y subcategorías</li>
          <li>✓ Imágenes de productos</li>
          <li>✓ Reportes y estadísticas avanzadas</li>
          <li>✓ Soporte técnico prioritario</li>
        </ul>
        <div class="contact-card">
          <div class="contact-header">Contáctanos</div>
          <div class="contact-info">
            <div class="contact-item">
              <span class="contact-icon">👤</span>
              <span class="contact-text">Yesid Rangel Orozco</span>
            </div>
            <div class="contact-item">
              <span class="contact-icon">📱</span>
              <span class="contact-text">321 123 4567</span>
            </div>
            <div class="contact-item">
              <span class="contact-icon">💼</span>
              <span class="contact-text">Desarrollador Full Stack</span>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button onclick="closeModal()" class="btn btn-secondary">Cerrar</button>
      </div>
    </div>
  </div>

  <footer class="footer">
    <div class="container">
      <p>&copy; <script>document.write(new Date().getFullYear())</script> Restaurante Tec Oriente</p>
    </div>
  </footer>

  <script>
    const productCount = <%= products.length %>;
    
    function validateProductLimit() {
      if (productCount >= 10) {
        showModal();
        return false;
      }
      return true;
    }
    
    function showModal() {
      document.getElementById('upgradeModal').style.display = 'flex';
    }
    
    function closeModal() {
      document.getElementById('upgradeModal').style.display = 'none';
    }
    
    window.onclick = function(event) {
      const modal = document.getElementById('upgradeModal');
      if (event.target === modal) {
        closeModal();
      }
    }
  </script>

  <script src="/js/main.js"></script>
</body>
</html>