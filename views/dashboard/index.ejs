<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pedidos - Restaurante</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="header">
    <div class="container">
      <h1 class="logo">🍽️ Restaurante Tec Oriente</h1>
      <nav class="nav">
        <% if (locals.user) { %>
          <a href="/tables" class="nav-link">Mesas</a>
          <a href="/products" class="nav-link">Productos</a>
          <a href="/dashboard" class="nav-link active">Pedidos</a>
          <a href="/orders" class="nav-link">Historial</a>
          <span class="nav-user">👤 <%= user.username %></span>
          <form action="/logout" method="POST" class="form-logout">
            <button type="submit" class="btn btn-logout">Salir</button>
          </form>
        <% } else { %>
          <a href="/login" class="nav-link">Ingresar</a>
          <a href="/register" class="nav-link">Registrarse</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="main">
    <div class="container">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">
          <%= error %>
        </div>
      <% } %>
      
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">
          <%= success %>
        </div>
      <% } %>

      <div class="page-header">
        <h2>Pedidos</h2>
        <p class="page-subtitle">Crea pedidos con productos y gestiona estados en tiempo real</p>
      </div>

      <!-- Layout superior: Crear pedido + Estadísticas -->
      <div class="dashboard-top-layout">
        <!-- Panel de Creación de Pedido -->
        <div class="card panel-create-full">
          <div class="card-header">
            <h3>📝 Crear Nuevo Pedido</h3>
          </div>
          <div class="card-body">
            <form action="/orders" method="POST" id="orderForm">
              <div class="form-row">
                <div class="form-group">
                  <label for="table_id">Mesa:</label>
                  <select id="table_id" name="table_id" required class="form-control">
                    <option value="">-- Seleccionar Mesa --</option>
                    <% tables.forEach(function(table) { %>
                      <option value="<%= table.id %>">Mesa <%= table.number %></option>
                    <% }); %>
                  </select>
                </div>
              </div>

              <div class="products-section">
                <h4>Productos del Pedido</h4>
                <div id="productsList">
                  <!-- Primer producto por defecto -->
                  <div class="product-item" data-index="0">
                    <div class="product-row">
                      <div class="form-group">
                        <label>Producto:</label>
                        <select name="products[0][product_id]" required class="form-control product-select">
                          <option value="">-- Seleccionar --</option>
                          <% products.forEach(function(product) { %>
                            <option value="<%= product.id %>" data-price="<%= product.price %>">
                              <%= product.name %> - $ <%= product.price.toFixed(2) %>
                            </option>
                          <% }); %>
                        </select>
                      </div>
                      <div class="form-group">
                        <label>Cantidad:</label>
                        <input type="number" name="products[0][quantity]" min="1" value="1" required class="form-control quantity-input">
                      </div>
                      <button type="button" class="btn btn-danger btn-remove" onclick="removeProduct(0)" style="display: none;">
                        ✕
                      </button>
                    </div>
                  </div>
                </div>
                
                <button type="button" class="btn btn-secondary" onclick="addProduct()">
                  + Agregar otro producto
                </button>
                
                <div class="total-preview">
                  <strong>Total estimado:</strong>
                  <span id="totalAmount">$ 0.00</span>
                </div>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-lg">
                  ✓ Crear Pedido
                </button>
              </div>
            </form>
            
            <% if (tables.length === 0) { %>
              <div class="alert alert-warning" style="margin-top: 1rem;">
                No hay mesas disponibles. <a href="/tables">Agregar mesas</a>
              </div>
            <% } %>
            
            <% if (products.length === 0) { %>
              <div class="alert alert-warning" style="margin-top: 1rem;">
                No hay productos disponibles. <a href="/products">Agregar productos</a>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Panel de Estadísticas (derecha) -->
        <div class="stats-panel">
          <div class="stats-header">
            <h3>📊 Resumen</h3>
          </div>
          <div class="stats-cards">
            <div class="stat-card stat-pending">
              <div class="stat-icon">⏳</div>
              <div class="stat-content">
                <div class="stat-number">
                  <%= orders.filter(o => o.status === 'pending').length %>
                </div>
                <div class="stat-label">Pendientes</div>
              </div>
            </div>
            
            <div class="stat-card stat-in_process">
              <div class="stat-icon">👨‍🍳</div>
              <div class="stat-content">
                <div class="stat-number">
                  <%= orders.filter(o => o.status === 'in_process').length %>
                </div>
                <div class="stat-label">En Proceso</div>
              </div>
            </div>
            
            <div class="stat-card stat-delivered">
              <div class="stat-icon">✅</div>
              <div class="stat-content">
                <div class="stat-number">
                  <%= orders.filter(o => o.status === 'delivered').length %>
                </div>
                <div class="stat-label">Entregados</div>
              </div>
            </div>
          </div>
          
          <div class="stats-total">
            <div class="total-label">Total Activos</div>
            <div class="total-number">
              <%= orders.filter(o => o.status !== 'paid').length %>
            </div>
          </div>
        </div>
      </div>

      <!-- Pedidos Activos -->
      <div class="card">
        <div class="card-header">
          <h3>📋 Gestión de Pedidos Activos</h3>
        </div>
        <div class="card-body">
          <% if (orders.length > 0) { %>
            <div class="orders-dashboard">
              <% orders.forEach(function(order) { %>
                <div class="order-card order-<%= order.status %>">
                  <div class="order-header">
                    <div class="order-info">
                      <span class="order-id">#<%= order.id %></span>
                      <span class="order-table">🪑 Mesa <%= order.table_number %></span>
                    </div>
                    <span class="badge badge-<%= order.status %>">
                      <% if (order.status === 'pending') { %>⏳ Pendiente<% } %>
                      <% if (order.status === 'in_process') { %>👨‍🍳 En Proceso<% } %>
                      <% if (order.status === 'delivered') { %>✅ Entregado<% } %>
                    </span>
                  </div>
                  
                  <div class="order-details">
                    <p><strong>Camarero:</strong> <%= order.username %></p>
                    <p><strong>Fecha:</strong> <%= new Date(order.created_at).toLocaleString('es-ES') %></p>
                  </div>
                  
                  <div class="order-actions-row">
                    <a href="/orders/<%= order.id %>" class="btn btn-info btn-sm">
                      📄 Ver Detalle
                    </a>
                    <% if (order.status === 'pending') { %>
                      <form action="/orders/<%= order.id %>/status" method="POST" class="status-form-inline">
                        <input type="hidden" name="status" value="in_process">
                        <button type="submit" class="btn btn-process btn-sm">
                          ▶ Iniciar
                        </button>
                      </form>
                    <% } %>
                    <% if (order.status === 'in_process') { %>
                      <form action="/orders/<%= order.id %>/status" method="POST" class="status-form-inline">
                        <input type="hidden" name="status" value="delivered">
                        <button type="submit" class="btn btn-deliver btn-sm">
                          ✓ Entregar
                        </button>
                      </form>
                    <% } %>
                    <% if (order.status === 'delivered') { %>
                      <form action="/orders/<%= order.id %>/status" method="POST" class="status-form-inline">
                        <input type="hidden" name="status" value="paid">
                        <button type="submit" class="btn btn-pay btn-sm">
                          $ Pagar
                        </button>
                      </form>
                    <% } %>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="empty-state">
              <div class="empty-icon">🎉</div>
              <p>No hay pedidos activos. ¡Todo está listo!</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2024 Restaurante Tec Oriente</p>
    </div>
  </footer>

  <script>
    let productCounter = 1;
    
    function addProduct() {
      const productsList = document.getElementById('productsList');
      const productItem = document.createElement('div');
      productItem.className = 'product-item';
      productItem.dataset.index = productCounter;
      
      productItem.innerHTML = `
        <div class="product-row">
          <div class="form-group">
            <label>Producto:</label>
            <select name="products[${productCounter}][product_id]" required class="form-control product-select">
              <option value="">-- Seleccionar --</option>
              <% products.forEach(function(product) { %>
                <option value="<%= product.id %>" data-price="<%= product.price %>">
                  <%= product.name %> - $ <%= product.price.toFixed(2) %>
                </option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>Cantidad:</label>
            <input type="number" name="products[${productCounter}][quantity]" min="1" value="1" required class="form-control quantity-input">
          </div>
          <button type="button" class="btn btn-danger btn-remove" onclick="removeProduct(${productCounter})">
            ✕
          </button>
        </div>
      `;
      
      productsList.appendChild(productItem);
      productCounter++;
      updateTotal();
      
      // Mostrar botones de eliminar en todos los items
      document.querySelectorAll('.btn-remove').forEach(btn => btn.style.display = 'inline-flex');
    }
    
    function removeProduct(index) {
      const item = document.querySelector(`.product-item[data-index="${index}"]`);
      if (item) {
        item.remove();
        updateTotal();
        
        // Ocultar botón eliminar si solo queda 1 producto
        const items = document.querySelectorAll('.product-item');
        if (items.length === 1) {
          items[0].querySelector('.btn-remove').style.display = 'none';
        }
      }
    }
    
    function updateTotal() {
      let total = 0;
      const items = document.querySelectorAll('.product-item');
      
      items.forEach(item => {
        const select = item.querySelector('.product-select');
        const quantity = item.querySelector('.quantity-input');
        
        if (select.value) {
          const option = select.options[select.selectedIndex];
          const price = parseFloat(option.dataset.price || 0);
          const qty = parseInt(quantity.value || 0);
          total += price * qty;
        }
      });
      
      document.getElementById('totalAmount').textContent = '$ ' + total.toFixed(2);
    }
    
    // Event listeners
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.product-select').forEach(select => {
        select.addEventListener('change', updateTotal);
      });
      document.querySelectorAll('.quantity-input').forEach(input => {
        input.addEventListener('change', updateTotal);
      });
    });
  </script>

  <script src="/js/main.js"></script>
</body>
</html>