<%- include('../layout', { 
  title: 'Dashboard - Pedidos Activos',
  body: `
    <div class="page-header">
      <h2>Dashboard de Pedidos</h2>
      <p class="page-subtitle">Gestiona el estado de los pedidos activos</p>
    </div>

    ${orders.length > 0 ? `
      <div class="orders-dashboard">
        ${orders.map(order => `
          <div class="order-card order-${order.status}">
            <div class="order-header">
              <div class="order-info">
                <span class="order-id">#${order.id}</span>
                <span class="order-table">Mesa ${order.table_number}</span>
              </div>
              <span class="badge badge-${order.status}">${getStatusLabel(order.status)}</span>
            </div>
            
            <div class="order-details">
              <p><strong>Camarero:</strong> ${order.username}</p>
              <p><strong>Fecha:</strong> ${new Date(order.created_at).toLocaleString('es-ES')}</p>
            </div>
            
            <div class="order-actions">
              ${getNextAction(order.status)}
            </div>
          </div>
        `).join('')}
      </div>
    ` : `
      <div class="card">
        <div class="card-body">
          <div class="empty-state">
            <p>No hay pedidos activos. <a href="/orders/new">Crear un nuevo pedido</a></p>
          </div>
        </div>
      </div>
    `}
  `
}) %>

<%- function getStatusLabel(status) {
  const labels = {
    'pending': 'Pendiente',
    'in_process': 'En Proceso',
    'delivered': 'Entregado',
    'paid': 'Pagado'
  };
  return labels[status] || status;
} %>

<%- function getNextAction(status) {
  const actions = {
    'pending': '<form action="/orders/${order.id}/status" method="POST" class="status-form"><input type="hidden" name="status" value="in_process"><button type="submit" class="btn btn-process btn-block">▶ Iniciar Preparación</button></form>',
    'in_process': '<form action="/orders/${order.id}/status" method="POST" class="status-form"><input type="hidden" name="status" value="delivered"><button type="submit" class="btn btn-deliver btn-block">✓ Marcar Entregado</button></form>',
    'delivered': '<form action="/orders/${order.id}/status" method="POST" class="status-form"><input type="hidden" name="status" value="paid"><button type="submit" class="btn btn-pay btn-block">$ Marcar Pagado</button></form>'
  };
  return actions[status] || '';
} %>