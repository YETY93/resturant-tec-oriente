<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lista de Pedidos</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="header">
    <div class="container">
      <h1 class="logo">🍽️ Restaurante Tec Oriente</h1>
      <nav class="nav">
        <% if (locals.user) { %>
          <a href="/tables" class="nav-link">Mesas</a>
          <a href="/products" class="nav-link">Productos</a>
          <a href="/dashboard" class="nav-link">Pedidos</a>
          <a href="/orders" class="nav-link active">Historial</a>
          <span class="nav-user">👤 <%= user.username %></span>
          <form action="/logout" method="POST" class="form-logout">
            <button type="submit" class="btn btn-logout">Salir</button>
          </form>
        <% } else { %>
          <a href="/login" class="nav-link">Ingresar</a>
          <a href="/register" class="nav-link">Registrarse</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="main">
    <div class="container">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">
          <%= error %>
        </div>
      <% } %>
      
      <div class="page-header">
        <h2>Historial de Pedidos</h2>
      </div>

      <div class="card">
        <div class="card-header">
          <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
            <h3>Pedidos</h3>
            <div class="filter-group">
              <label for="filter">Filtrar por estado:</label>
              <select id="filter" class="form-control" onchange="window.location.href='/orders?status=' + this.value">
                <option value="all" <%= locals.filter === 'all' ? 'selected' : '' %>>Todos</option>
                <option value="pending" <%= locals.filter === 'pending' ? 'selected' : '' %>>Pendientes</option>
                <option value="in_process" <%= locals.filter === 'in_process' ? 'selected' : '' %>>En Proceso</option>
                <option value="delivered" <%= locals.filter === 'delivered' ? 'selected' : '' %>>Entregados</option>
                <option value="paid" <%= locals.filter === 'paid' ? 'selected' : '' %>>Pagados</option>
              </select>
            </div>
          </div>
        </div>
        <div class="card-body">
          <% if (orders.length > 0) { %>
            <div class="table-responsive">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Mesa</th>
                    <th>Usuario</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                  </tr>
                </thead>
                <tbody>
                  <% orders.forEach(function(order) { %>
                    <tr class="row-<%= order.status %>">
                      <td><strong>#<%= order.id %></strong></td>
                      <td>Mesa <%= order.table_number %></td>
                      <td><%= order.username %></td>
                      <td>
                        <span class="badge badge-<%= order.status %>">
                          <% if (order.status === 'pending') { %>Pendiente<% } %>
                          <% if (order.status === 'in_process') { %>En Proceso<% } %>
                          <% if (order.status === 'delivered') { %>Entregado<% } %>
                          <% if (order.status === 'paid') { %>Pagado<% } %>
                        </span>
                      </td>
                      <td><%= new Date(order.created_at).toLocaleString('es-ES') %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="empty-state">
              <p>No hay pedidos con ese filtro. <a href="/orders/new">Crear un nuevo pedido</a></p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2024 Restaurante Tec Oriente</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>